# =============================================================================
# Vujy — Variables de entorno de referencia
# Copiar a .env.local para desarrollo local
# NUNCA commitear .env.local ni .env con valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Proyecto local (supabase start)
# Para producción, usar los valores del dashboard de Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# PELIGRO: nunca usar NEXT_PUBLIC_ para esta clave — solo server-side
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# -----------------------------------------------------------------------------
# Database — Drizzle ORM (conexión directa — pooler deshabilitado en local)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL_DIRECT=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# LLM Provider — configurable sin cambios de código
# Cambiar LLM_PROVIDER para alternar entre proveedores
# -----------------------------------------------------------------------------
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-6
# PELIGRO: nunca usar NEXT_PUBLIC_ para esta clave — solo server-side
LLM_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Rate limiting — ver lib/rate-limit.ts
# SESSION_RATE_LIMIT_MAX: máx. requests permitidos por ventana (default: 10)
# SESSION_RATE_LIMIT_WINDOW_MS: tamaño de la ventana en ms (default: 60000 = 1 min)
# -----------------------------------------------------------------------------
# SESSION_RATE_LIMIT_MAX=10
# SESSION_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# WhatsApp (Meta Cloud API) — configurar en feature 003-whatsapp-infra
# -----------------------------------------------------------------------------
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Mercado Pago — configurar en feature 007-payments
# -----------------------------------------------------------------------------
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Monitoring — configurar antes del primer deploy a producción
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
